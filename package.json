{
  "name": "proactive-ai-desktop",
  "version": "1.1.0",
  "description": "Proactive AI Chat - 桌面版",
  "main": "./out/main/index.js",
  "author": "ProactiveAI",
  "license": "MIT",
  "scripts": {
    "dev": "electron-vite dev",
    "gen:pavatar-demo": "node scripts/generate-builtin-pavatar-demo.cjs",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "dist": "npm run build && electron-builder",
    "dist:win": "npm run build && electron-builder --win",
    "dist:win:fresh": "node scripts/clean-electron-win-cache.cjs && npm run dist:win",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:linux": "npm run build && electron-builder --linux"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electron-store": "^11.0.2",
    "framer-motion": "^12.34.4",
    "highlight.js": "^11.11.1",
    "i18next": "^26.0.4",
    "immer": "^11.1.4",
    "lowdb": "^7.0.1",
    "lucide-react": "^0.468.0",
    "mermaid": "^11.14.0",
    "openai": "^6.25.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-i18next": "^17.0.2",
    "react-markdown": "^10.1.0",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.5.0",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@types/lowdb": "^1.0.15",
    "@types/node": "^22.10.5",
    "@types/react": "^19.0.6",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^4.3.5",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.1.2",
    "electron": "^34.2.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^5.0.0",
    "png-to-ico": "^3.0.1",
    "pngjs": "^7.0.0",
    "postcss": "^8.5.8",
    "rcedit": "^5.0.2",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.7.3",
    "vite": "^6.0.7"
  },
  "build": {
    "appId": "com.proactiveai.desktop",
    "productName": "ProactiveAI",
    "directories": {
      "output": "release"
    },
    "afterPack": "./scripts/after-pack-win-icon.cjs",
    "files": [
      "out/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "resources/pavatar-bundled",
        "to": "pavatar-bundled"
      }
    ],
    "win": {
      "icon": "build/icon.png",
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "mac": {
      "icon": "build/icon.png",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ]
    },
    "linux": {
      "icon": "build/icon.png",
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ]
    }
  }
}
